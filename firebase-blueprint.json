{
  "entities": {
    "Client": {
      "title": "Client",
      "description": "Information about a client dossier, active status, and audit progress.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "mail": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "services": { "type": "string" },
        "document": { "type": "string" },
        "usernames": { "type": "string" },
        "passwords": { "type": "string" },
        "website": { "type": "string" },
        "paymentPlan": { "type": "string" },
        "noteKey": { "type": "string" },
        "onboardedAt": { "type": "string" },
        "status": { "type": "string" },
        "auditStatus": { "type": "string" },
        "auditProgress": { "type": "number" },
        "activeAgentIndex": { "type": "number" },
        "agentOutputs": { "type": "object" }
      },
      "required": ["id", "name", "mail"]
    },
    "AgentTask": {
      "title": "AgentTask",
      "description": "Represents an active multi-agent task and its live tracker progress.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "clientName": { "type": "string" },
        "agentRole": { "type": "string" },
        "agentName": { "type": "string" },
        "status": { "type": "string" },
        "progress": { "type": "number" },
        "description": { "type": "string" },
        "currentStep": { "type": "string" },
        "dispatchedAt": { "type": "string" }
      },
      "required": ["id", "title", "agentRole", "status"]
    },
    "Agreement": {
      "title": "Agreement",
      "description": "Smart agreement draft details generated by the agency operations.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "category": { "type": "string" },
        "clientName": { "type": "string" },
        "clientEmail": { "type": "string" },
        "website": { "type": "string" },
        "servicesScope": { "type": "string" },
        "paymentTerms": { "type": "string" },
        "duration": { "type": "string" },
        "specificClauses": { "type": "string" },
        "draftContent": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "clientName", "clientEmail"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "Chat message inside the operational console.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "role": { "type": "string" },
        "sender": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["id", "role", "text"]
    },
    "SystemLog": {
      "title": "SystemLog",
      "description": "Durable neural core execution status logs.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "string" },
        "source": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string" }
      },
      "required": ["id", "timestamp", "source", "message", "type"]
    }
  },
  "firestore": {
    "clients/{clientId}": {
      "schema": "Client",
      "description": "Collection of client dossiers"
    },
    "tasks/{taskId}": {
      "schema": "AgentTask",
      "description": "Collection of active multi-agent pipeline tasks"
    },
    "agreements/{agreementId}": {
      "schema": "Agreement",
      "description": "Collection of generated legal smart agreements"
    },
    "chatHistory/{messageId}": {
      "schema": "ChatMessage",
      "description": "Collection of chat console dialogues"
    },
    "systemLogs/{logId}": {
      "schema": "SystemLog",
      "description": "Collection of system and agent execution log histories"
    }
  }
}
